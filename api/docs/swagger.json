          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "ID del usuario cuyo rol se desea modificar"
          }
        ],
        "responses": {
          "200": {
            "description": "Rol actualizado correctamente",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "example": "string"
                    },
                    "example": {
                      "type": "string",
                      "example": "Rol actualizado correctamente"
                    }
                  }
                },
                "group": {
                  "$ref": "#/components/schemas/Group"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "400": {
            "description": "Rol inválido"
          },
          "403": {
            "description": "No autorizado para modificar el rol"
          },
          "404": {
            "description": "Grupo o usuario no encontrado"
          },
          "500": {
            "description": "Error interno del servidor"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "role": {
                    "type": "string",
