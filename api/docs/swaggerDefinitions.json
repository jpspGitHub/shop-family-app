{
  "info": {
    "title": "Shop Family API",
    "description": "API para la aplicación Shop Family"
  },
  "host": "localhost:5001",
  "schemes": [
    "http"
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Endpoints de autenticación"
    },
    {
      "name": "Users",
      "description": "Gestión de usuarios"
    },
    {
      "name": "Groups",
      "description": "Gestión de grupos"
    },
    {
      "name": "Items",
      "description": "Gestión de ítems"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "description": "Login con Google",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inicio de sesión exitoso"
          },
          "401": {
            "description": "Token inválido o expirado"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "description": "Cierra sesión e invalida el token actual",
        "responses": {
          "200": {
            "description": "Logout exitoso"
          },
          "500": {
            "description": "Error al cerrar sesión"
          }
        }
      }
    },
    "/groups": {
      "post": {
        "tags": [
          "Groups"
        ],
        "description": "Crear un nuevo grupo",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Mi Grupo"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Grupo creado correctamente"
          },
          "500": {
            "description": "Error al crear el grupo"
          },
          "400": {
            "description": "Error en los datos enviados"
          },
        }
      },
      "get": {
        "tags": [
          "Groups"
        ],
        "description": "Obtener los grupos del usuario",
        "responses": {
          "200": {
            "description": "Lista de grupos"
          },
          "500": {
            "description": "Error al obtener los grupos"
          }
        }
      }
    },
    "/groups/{id}": {
      "put": {
        "tags": [
          "Groups"
        ],
        "description": "Actualizar un grupo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "64f1d15ecf11bb34bc001122"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Grupo actualizado"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Grupo actualizado correctamente"
          },
          "404": {
            "description": "Grupo no encontrado"
          }
        }
      },
      "delete": {
        "tags": [
          "Groups"
        ],
        "description": "Eliminar un grupo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "64f1d15ecf11bb34bc001122"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Grupo eliminado correctamente"
          },
          "404": {
            "description": "Grupo no encontrado"
          }
        }
      }
    }
  }
}